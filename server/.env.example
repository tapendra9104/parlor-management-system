# ============================================
# SalonFlow — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# ─── Required ──────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/salonflow
JWT_SECRET=generate-with-npm-run-generate-secret

# ─── Optional ──────────────────────────────
PORT=5000
NODE_ENV=development
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# ─── JWT Rotation (Gap #3) ─────────────────
# Set this to your old JWT_SECRET when rotating secrets.
# Tokens signed with this secret will still be valid during the transition.
JWT_PREVIOUS_SECRET=

# ─── Razorpay Payment Gateway ─────────────
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx

# ─── Gemini AI Chatbot ────────────────────
GEMINI_API_KEY=

# ─── Email (Nodemailer) ───────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ─── Demo Mode (Gap #8) ───────────────────
# Set to 'false' in production to disable demo/fallback data
DEMO_MODE=true
